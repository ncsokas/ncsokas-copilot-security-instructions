{
  "version": 1,
  "hooks": {
    "sessionEnd": [
      {
        "type": "command",
        "bash": ".github/hooks/scan-secrets.sh",
        "cwd": ".",
        "env": {
          "SCAN_MODE": "block",
          "SCAN_SCOPE": "diff",
          "EXCLUDED_DIRS": ".github/,demo/"
        },
        "timeoutSec": 30
      }
    ]
  }
}